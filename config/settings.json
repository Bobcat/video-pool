{
  "service": {
    "host": "127.0.0.1",
    "port": 8014,
    "log_level": "info",
    "artifact_root": "data/videos"
  },
  "engine": {
    "backend": "stub",
    "models": {
      "stub-video": {
        "backend": "stub",
        "enabled": true,
        "target_inflight": 1,
        "modalities": ["text", "image"],
        "output_modalities": ["video"],
        "tasks": ["text_to_video", "image_to_video"],
        "max_images": 1,
        "max_output_videos": 1,
        "vram_estimate_mib": 0,
        "recommended_steps": 4,
        "recommended_guidance": 1.0,
        "generation_parameters": {
          "size": {"kind": "enum", "target": "request", "default": "832x480", "allowed_values": ["512x512", "832x480", "480x832", "1280x704", "704x1280"]},
          "duration_seconds": {"kind": "number", "target": "request", "default": 5.0, "minimum": 0.5, "maximum": 60.0, "step": 0.5},
          "fps": {"kind": "integer", "target": "request", "default": 16, "minimum": 1, "maximum": 60, "step": 1},
          "num_frames": {"kind": "integer_or_null", "target": "request", "default": null, "minimum": 1, "maximum": 600, "step": 1},
          "n": {"kind": "integer", "target": "request", "default": 1, "minimum": 1, "maximum": 1, "step": 1},
          "steps": {"kind": "integer", "target": "metadata", "default": 4, "minimum": 1, "maximum": 80, "step": 1},
          "guidance": {"kind": "number", "target": "metadata", "default": 1.0, "minimum": 0.0, "maximum": 20.0, "step": 0.1},
          "seed": {"kind": "integer_or_null", "target": "request", "default": null, "minimum": 0, "step": 1}
        },
        "image_to_video_parameters": {
          "size": {"kind": "enum", "target": "request", "default": "832x480", "allowed_values": ["512x512", "832x480", "480x832", "1280x704", "704x1280"]},
          "duration_seconds": {"kind": "number", "target": "request", "default": 5.0, "minimum": 0.5, "maximum": 60.0, "step": 0.5},
          "fps": {"kind": "integer", "target": "request", "default": 16, "minimum": 1, "maximum": 60, "step": 1},
          "num_frames": {"kind": "integer_or_null", "target": "request", "default": null, "minimum": 1, "maximum": 600, "step": 1},
          "n": {"kind": "integer", "target": "request", "default": 1, "minimum": 1, "maximum": 1, "step": 1},
          "steps": {"kind": "integer", "target": "metadata", "default": 4, "minimum": 1, "maximum": 80, "step": 1},
          "guidance": {"kind": "number", "target": "metadata", "default": 1.0, "minimum": 0.0, "maximum": 20.0, "step": 0.1},
          "seed": {"kind": "integer_or_null", "target": "request", "default": null, "minimum": 0, "step": 1}
        }
      }
    }
  }
}

